{
    "compilerOptions": {
    "target": "ES2020",
    "resolveJsonModule": true,   
    "outDir": "./dist",                          
    "module": "NodeNext",                                                            
     "moduleResolution": "nodenext",                                                   
     "allowSyntheticDefaultImports": true,            
    "esModuleInterop": true,                           
    "forceConsistentCasingInFileNames": true,           
    "strict": true,                                      
    "skipLibCheck": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "baseUrl": ".",
    "paths": {
          "@checkers/*": [
            "src/botDetector/checkers/*"
          ],
          "@db/*": [
            "src/botDetector/db/*"
          ],
          "@helpers/*": [
            "src/botDetector/helpers/*"
          ],
          "@utils/*": [
            "src/botDetector/utils/*"
          ],
          "~~/*": [
            "./*"
          ]
    }
  },

  "include": ["src/**/*",  "src/**/*.json", "test/**/*"],
  "exclude": ["node_modules"]
}
