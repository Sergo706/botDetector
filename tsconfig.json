{
    "compilerOptions": {
    "target": "ES2020",
    "resolveJsonModule": true,   
    "rootDir": "./src",
    "outDir": "dist",                          
    "module": "NodeNext",                                                            
     "moduleResolution": "nodenext",                                                   
     "allowSyntheticDefaultImports": true,            
    "esModuleInterop": true,                           
    "forceConsistentCasingInFileNames": true,           
    "strict": true,                                      
    "skipLibCheck": true,
    "composite": true                          
  },
  "include": ["src/**/*",  "src/**/*.json"],
  "exclude": ["node_modules"]
}
